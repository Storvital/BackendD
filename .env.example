# ============================================================
#  STORVITAL — Variables d'environnement backend
#  Copiez ce fichier en ".env" pour le développement local.
#  Sur Render : saisir ces variables dans Environment Variables.
#  Ne jamais commiter le fichier .env réel dans Git.
# ============================================================

# Clé SECRÈTE Stripe (sk_test_... ou sk_live_...)
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE_STRIPE

# Secret Webhook Stripe (Dashboard Stripe → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_WEBHOOK

# URL exacte du front Netlify (sans slash final)
# Utilisée pour les redirections Stripe et la configuration CORS
FRONTEND_URL=https://storvital.netlify.app

# Port local (Render l'injecte automatiquement en production)
PORT=3000

# Environnement
NODE_ENV=development
